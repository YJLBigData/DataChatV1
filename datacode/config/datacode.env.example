# 本地启动脚本会优先读取 config/datacode.env。
# 复制本文件为 config/datacode.env 后填入真实凭证；不要提交真实密钥。

DATACODE_SERVER_PORT=18082

# Qwen / DashScope OpenAI 兼容接口
DATACODE_LLM_MODEL=qwen3.6-max-preview
DATACODE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DATACODE_LLM_API_KEY=

# MaxCompute / Dataphin 查询凭证
ALIYUN_DATA_PLATFORM_AK=
ALIYUN_DATA_PLATFORM_SK=
DATAPHIN_DEFAULT_PROJECT=firmus_dataphin_prd_ads

# ===== DataChat SSO（与 DataChatV1 共用登录态）=====
# 生产环境保持 true：DataCode 不再接受本地账号密码，统一走 DataChatV1 token。
DATACODE_SSO_ENABLED=true
# 同机部署写本机回环，避免走公网；跨机部署时填 DataChatV1 后端的内网地址。
DATACODE_SSO_DATACHAT_BASE_URL=http://127.0.0.1:8001
DATACODE_SSO_CACHE_SECONDS=60
DATACODE_SSO_LOGIN_REDIRECT=/web/#/chat
