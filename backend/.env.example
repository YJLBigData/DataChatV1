# DataChat 本地运行环境
# ==================
# 复制为 backend/.env 后填写敏感信息，不要提交到 Git。

# --- 应用 ---
APP_NAME=DataChat
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8001
LOG_LEVEL=INFO

# --- 业务数据库（本机 MySQL chatbi 库） ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=请填写本机 MySQL root 密码
MYSQL_DATABASE=chatbi

# --- 阿里云百炼 / DashScope（唯一 LLM 入口） ---
DASHSCOPE_API_KEY=sk-请填写阿里百炼 API key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.6-max-preview
DASHSCOPE_EMBED_MODEL=text-embedding-v3

# --- Redis 缓存（默认本机 6379） ---
DATACHAT_REDIS_URL=redis://127.0.0.1:6379/2
DATACHAT_CACHE_ENABLED=1

# --- JWT / 管理员 ---
# 生产必须改为强随机值：python3 -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=请填写强随机 JWT 密钥（≥32位）
# 留空：首次启动自动生成一次性强口令 → backend/logs/INITIAL_ADMIN_PASSWORD.txt（强制首登改密）
# 生产建议显式设置仅你知道的强口令；切勿把真实口令提交到 Git
DATACHAT_ADMIN_PASSWORD=

# --- 用户/权限本地 SQLite（生产部署也使用服务器本地文件，不写业务库） ---
USER_DIRECTORY=local
DB_USERS_ENABLED=0
DATACHAT_AUTH_DB=logs/user_store.db
DATACHAT_PERMISSIONS_DB=logs/user_store.db

# --- 飞书机器人（可选） ---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK=
FEISHU_DEFAULT_USER_EMAIL=
