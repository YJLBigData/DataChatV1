# 本地执行环境配置（APP_ENV=local 时自动加载）
# 业务库走你本地的 MySQL；用户与权限走本地 SQLite。 本文件不含任何密钥，可入库。
# 优先级：真实环境变量 / backend/.env > 本文件。本地真实账号密码请写 backend/.env。

APP_ENV=local
APP_DEBUG=true

# —— 本地 MySQL（业务库）——
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=chatbi
MYSQL_USER=root
# 本地 MySQL 密码请写到 backend/.env（键名 MYSQL_PASSWORD），切勿写入本文件/入库

# 用户体系：本地 SQLite，和业务库解耦。
USER_DIRECTORY=local
DB_USERS_ENABLED=0
DATACHAT_AUTH_DB=logs/user_store.db
DATACHAT_PERMISSIONS_DB=logs/user_store.db
# 本地管理员初始密码请写到 backend/.env（键 DATACHAT_ADMIN_PASSWORD），
# 不要写进本文件——committed 配置文件保持零口令。

# 本地大模型仍用百炼/DashScope（key 写 backend/.env: DASHSCOPE_API_KEY=xxx）
LLM_PROVIDER=bailian

# 本地缓存
DATACHAT_REDIS_URL=redis://127.0.0.1:6379/2

# 本地 CORS 放开
CORS_ALLOW_ORIGINS=
