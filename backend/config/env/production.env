# 服务器执行环境配置（APP_ENV=production 时自动加载）
# 业务库走服务器 MySQL；用户与权限走服务器本地 SQLite。 本文件只含非敏感默认值，可入库。
# 真实连接串/密钥(DB_HOST/DB_USER/DB_PASSWORD/AES_KEY/JWT_SECRET) 只允许出现在
# 服务器本地 /opt/datachatv1/.env（部署脚本写入，chmod 600，禁止入 Git）。
# 部署脚本会 `set -a; source /opt/datachatv1/.env`，真实环境变量优先级最高，覆盖本文件。

APP_ENV=production
APP_DEBUG=false

# —— 服务器 MySQL（业务库 hs_poc，只读查询）——
DB_PORT=3306
DB_NAME=hs_poc
# DB_HOST / DB_USER / DB_PASSWORD 来自 /opt/datachatv1/.env（真实值，不入库）

# 用户体系：服务器本地 SQLite，绝不依赖业务库建 users 表。
USER_DIRECTORY=local
DB_USERS_ENABLED=0
DATACHAT_AUTH_DB=/opt/datachatv1/logs/user_store.db
DATACHAT_PERMISSIONS_DB=/opt/datachatv1/logs/user_store.db

# 公司统一大模型网关（非敏感参数；AES_KEY 来自 /opt/datachatv1/.env）
LLM_PROVIDER=feihe
FEIHE_AGENT_API_URL=https://adp-test.feihe.com/adp-engine/v1/agent/chat
FEIHE_SERVICE_OPEN_ID=data_middle_platform
FEIHE_AUTHENTICATOR=AES
FEIHE_AGENT_CODE=kaier_znws
FEIHE_TENANT_CODE=data_middle_platform
FEIHE_CHANNEL=d2b-order
FEIHE_AGENT_DEBUG=true

DATACHAT_REDIS_URL=redis://127.0.0.1:6379/2

# 上线务必在 /opt/datachatv1/.env 用真实前端域名覆盖
CORS_ALLOW_ORIGINS=
