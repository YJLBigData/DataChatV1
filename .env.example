APP_NAME=DataChatV1
APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=8001
APP_PUBLIC_BASE_URL=https://datachatv1.feihe.com

DATACHAT_BACKEND_VERSION=v1
DATACHAT_CONFIG_OVERLAYS=settings_v1.yaml
DATABASE_URL=mysql+pymysql://user:password@host:3306/datachatv1_meta?charset=utf8mb4
DATACHAT_ALLOW_SQLITE_METADATA=false
JWT_SECRET=请部署时填写强随机字符串
USER_DIRECTORY=local
DB_USERS_ENABLED=0
DATACHAT_AUTH_DB=/opt/datachatv1/logs/user_store.db
DATACHAT_PERMISSIONS_DB=/opt/datachatv1/logs/user_store.db

MYSQL_HOST=请部署时填写业务数据库地址
MYSQL_PORT=3306
MYSQL_DATABASE=请部署时填写业务数据库名
MYSQL_USER=请部署时填写业务数据库用户
MYSQL_PASSWORD=请部署时填写业务数据库密码

FEIHE_LLM_BASE_URL=https://adp-test.feihe.com/adp-engine/v1/agent/chat
FEIHE_LLM_SERVICE_OPEN_ID=data_middle_platform
FEIHE_LLM_AUTHENTICATOR=AES
FEIHE_LLM_AES_KEY=
FEIHE_LLM_AGENT_CODE=kaier_znws
FEIHE_LLM_TENANT_CODE=data_middle_platform
FEIHE_LLM_CHANNEL=d2b-order
FEIHE_LLM_DEBUG=true
FEIHE_LLM_UID=
FEIHE_LLM_CUSTOMER_ID=

SQL_QUERY_TIMEOUT_SECONDS=60
SQL_DEFAULT_LIMIT=500
SQL_MAX_LIMIT=5000

LOG_LEVEL=INFO
TRACE_RETENTION_DAYS=14
QUERY_LOG_RETENTION_DAYS=90

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
