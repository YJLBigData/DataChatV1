# 服务器部署脚本允许写真实 DB/AES/JWT 密钥，只保留在本地/服务器，不入库
deploy/deploy_datachatv1.sh
start_server.sh

# safe_push 本地私有敏感词 denylist（项目专属真实密码/主机/账号，绝不入库）
scripts/.secret_denylist

.venv/
**/.venv/
backend/.venv
venv/
env/
